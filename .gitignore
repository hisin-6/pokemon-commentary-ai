# 仮想環境
venv/

# Pythonキャッシュ
__pycache__/
*.pyc
*.pyo

# EasyOCRモデルキャッシュ
.EasyOCR/

# デバッグ用スクショ（screen_capture.pyが自動生成）
debug/

# パイプラインログ（pipeline.pyが自動生成）
logs/

# テスト・学習用画像（大きいのでGit管理しない）
data/test_images/ocr/*.png
data/test_images/ocr/*.jpg
data/test_images/diff_detection/*.png
data/test_images/diff_detection/*.jpg
data/yolo_dataset/images/**/*.png
data/yolo_dataset/images/**/*.jpg
data/yolo_dataset/labels/**/*.txt

# ただしREADMEは含める
!data/**/README.md

# 環境変数・秘密情報
.env
*.key

# YOLOv8 学習出力（モデルウェイト・ログ等）
runs/

# PyTorch モデルウェイト（自動DLされるもの・学習済みモデル）
*.pt

# OS
.DS_Store
Thumbs.db
